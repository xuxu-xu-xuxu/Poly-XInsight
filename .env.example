FRONTEND_PORT=3000
INGESTION_CONCURRENCY=2
EMBEDDING_BATCH_SIZE=20
LLM_EXTRACT_CONCURRENCY=2
ENABLE_STRUCTURED_EXTRACTION=false
EXTRACTION_CONFIDENCE_THRESHOLD=0.7
